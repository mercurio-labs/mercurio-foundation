                                                     "specializes":  "$ast.specializes or semantic_default",
                                                     "type":  "$ast.ty"
                                                 }
                                  },
                      "elaborate":  [

                                    ],
                      "emit":  {
                                   "id_template":  "feature.{owner_path}.{declared_name}",
                                   "properties":  {
                                                      "declared_name":  "$declared_name",
                                                      "direction":  "$direction",
                                                      "features":  "$features",
                                                      "featuring_type":  "$featuring_type",
                                                      "is_abstract":  "$is_abstract",
                                                      "is_derived":  "$is_derived",
                                                      "is_end":  "$is_end",
                                                      "is_ordered":  "$is_ordered",
                                                      "is_unique":  "$is_unique",
                                                      "is_variable":  "$is_variable",
                                                      "members":  "$members",
                                                      "metatype":  "$metatype",
                                                      "name":  "$name",
                                                      "owner":  "$owner",
                                                      "redefined_features":  "$redefined_features",
                                                      "specialized_features":  "$specialized_features",
                                                      "specializes":  "$specializes",
                                                      "subsetted_features":  "$subsetted_features",
                                                      "type":  "$type"
                                                  }
                               },
                      "pilot_sources":  {
                                            "grammar_rules":  [
                                                                  "AttributeUsage"
                                                              ],
                                            "ecore_class":  "SysML::AttributeUsage",
                                            "transform_observations":  [

                                                                       ]
                                        }
                  },
                  {
                      "construct":  "ConnectionDefinition",
                      "metaclass":  "SysML::ConnectionDefinition",
                      "status":  "reviewed",
                      "ast":  {
                                  "node":  "GenericDefinitionDecl",
                                  "keyword":  "connection"
                              },
                      "collect":  {
                                      "element":  "definition",
                                      "name":  "$ast.name",
                                      "owner":  "$scope.package_or_definition",
                                      "fields":  {
                                                     "end_members":  "$ast.members[modifier=end]",
                                                     "members":  "$ast.members[usage]",
                                                     "specializes":  "$ast.specializes or semantic_default"
                                                 }
                                  },
                      "elaborate":  [
                                        {
                                            "id":  "connection-end-direction",
                                            "when":  "$definition.construct == ConnectionDefinition",
                                            "set":  {
                                                        "first_end_modifier":  "end-source",
                                                        "second_end_modifier":  "end-target"
                                                    },
                                            "note":  "Matches current Rust annotation of binary connection ends before semantic specialization."
                                        }
                                    ],
                      "emit":  {
                                   "id_template":  "type.{qualified_name}",
                                   "properties":  {
                                                      "features":  "$owned_feature_ids",
                                                      "members":  "$member_ids",
                                                      "metatype":  "$metatype_ref",
                                                      "owner":  "$owner_id",
                                                      "specializes":  "$specializes_refs"
                                                  }
                               },
                      "pilot_sources":  {
                                            "grammar_rules":  [
                                                                  "ConnectionDefinition"
                                                              ],
                                            "ecore_class":  "SysML::ConnectionDefinition",
                                            "transform_observations":  [
                                                                           "connection-end-direction"
                                                                       ]
                                        }
                  },
