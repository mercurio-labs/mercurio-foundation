                  {
                      "construct":  "ReferenceUsage",
                      "metaclass":  "SysML::ReferenceUsage",
                      "status":  "reviewed",
                      "ast":  {
                                  "node":  "GenericUsageDecl",
                                  "keyword":  "reference"
                              },
                      "collect":  {
                                      "element":  "usage",
                                      "name":  "$ast.name",
                                      "owner":  "$scope.owner",
                                      "fields":  {
                                                     "reference_target":  "$ast.reference_target",
                                                     "redefines":  "$ast.redefines",
                                                     "type":  "$ast.ty"
                                                 }
                                  },
                      "elaborate":  [
                                        {
                                            "id":  "implicit-ref-redefines-target",
                                            "when":  "$usage.is_implicit_name \u0026\u0026 $usage.declared_name == ref \u0026\u0026 empty($usage.type) \u0026\u0026 empty($usage.reference_target) \u0026\u0026 len($usage.redefines) == 1",
                                            "set":  {
                                                        "reference_target":  "$usage.redefines[0]",
                                                        "redefines":  "[]"
                                                    },
                                            "note":  "Matches current Rust lowering behavior for implicit reference shorthand."
                                        }
                                    ],
                      "emit":  {
                                   "id_template":  "feature.{qualified_name}",
                                   "properties":  {
                                                      "metatype":  "$metatype_ref",
                                                      "owner":  "$owner_id",
                                                      "specialized_features":  "$reference_target_ref",
                                                      "specializes":  "$specializes_refs",
                                                      "type":  "$type_ref"
                                                  }
                               },
