{
  "schema_version": 1,
  "reference_usage_semantics": {
    "modifier_rules": [
      {
        "modifier": "payload",
        "synthetic_declared_name": true,
        "subsetted_feature_refs": [
          "Objects::objects"
        ],
        "redefined_feature_refs": [
          "payload"
        ],
        "direction": "in"
      },
      {
        "modifier": "source-output",
        "synthetic_declared_name": true,
        "default_type_ref": "Ports::Port",
        "semantic_specializations": [],
        "redefined_feature_refs": [
          "$declared_name",
          "Transfers::sourceOutput"
        ]
      },
      {
        "modifier": "target-input",
        "synthetic_declared_name": true,
        "default_type_ref": "Occurrences::Occurrence",
        "semantic_specializations": [],
        "redefined_feature_refs": [
          "$declared_name",
          "Transfers::targetInput"
        ],
        "direction_from_modifier": "in"
      },
      {
        "modifier": "receiver",
        "synthetic_declared_name": true,
        "default_type_ref": "Occurrences::Occurrence",
        "semantic_specializations": [],
        "redefined_feature_refs": [
          "receiver"
        ],
        "direction_from_modifier": "in"
      }
    ],
    "typed_data_value": {
      "subsetted_feature_refs": [
        "Base::dataValues"
      ]
    },
    "typed_object": {
      "subsetted_feature_refs": [
        "Objects::objects"
      ],
      "direction_from_modifiers": [
        "in",
        "out",
        "inout"
      ]
    }
  },
  "definition_context": {
    "abstract_constructs": [
      "EnumerationDefinition"
    ]
  },
  "usage_context": {
    "non_variable_owner_constructs": [
      "AttributeDefinition",
      "EnumerationDefinition",
      "Package"
    ],
    "no_type_context_owner_constructs": [
      "EnumerationDefinition",
      "Package"
    ],
    "non_owned_member_constructs": [
      "ConnectionUsage"
    ],
    "direction_modifiers": [
      "inout",
      "in",
      "out"
    ]
  },
  "usage_type_defaults": {
    "AttributeUsage": {
      "type_ref": "Base::DataValue"
    },
    "EnumerationUsage": {
      "owner_type_refs": {
        "EnumerationDefinition": "$owner_qualified_name"
      }
    },
    "PartUsage": {
      "type_ref": "Parts::Part"
    },
    "PortUsage": {
      "type_ref": "Ports::Port"
    }
  },
  "usage_property_defaults": {
    "AcceptActionUsage": [
      {
        "property_values": {
          "source": "$owner_id",
          "trigger": "$modifier_value_trigger",
          "trigger_kind": "$modifier_value_trigger_kind",
          "target": "$sibling_state_id_transition_target"
        }
      }
    ],
    "AllocationUsage": [
      {
        "property_values": {
          "allocated": "$allocation_source",
          "allocated_to": "$allocation_target",
          "source": "$allocation_source",
          "target": "$allocation_target"
        }
      }
    ],
    "CommentUsage": [
      {
        "property_values": {
          "annotatedElement": "$reference_target",
          "body": "$metadata_body",
          "locale": "$metadata_locale"
        }
      }
    ],
    "PartUsage": [
      {
        "owner_construct": "ItemDefinition",
        "absent_modifiers": [
          "ref"
        ],
        "property_refs": {
          "type": [
            "Parts::Part"
          ],
          "definition": [
            "Parts::Part"
          ]
        }
      }
    ],
    "SatisfyUsage": [
      {
        "kir_kind": "SysML::Requirements::SatisfyRequirementUsage",
        "property_values": {
          "source": "$owner_id",
          "target": "$reference_target"
        }
      }
    ],
    "StateUsage": [
      {
        "owner_construct": "StateUsage",
        "property_values": {
          "parent_state": "$owner_id"
        }
      }
    ],
    "SuccessionUsage": [
      {
        "present_modifiers": [
          "then"
        ],
        "property_values": {
          "target": "state.$qualified_name",
          "trigger_kind": "completion"
        }
      }
    ],
    "VerifyUsage": [
      {
        "kir_kind": "SysML::Requirements::VerifyRequirementUsage",
        "property_values": {
          "source": "$owner_id",
          "target": "$reference_target"
        }
      }
    ]
  },
  "usage_actions": {
    "AcceptActionUsage": [
      {
        "action": "source_from_previous_sibling_state",
        "requires_previous_state": true
      }
    ],
    "MetadataUsage": [
      {
        "action": "attach_metadata_application",
        "requires_metadata_properties": true,
        "target": "$reference_target_or_owner"
      }
    ]
  },
  "usage_specialization_policies": {
    "PerformActionUsage": {
      "materialized_refs_policy": "prepend_feature_for_specialized_actions_without_multiplicity"
    }
  },
  "usage_resolution_policies": {
    "CommentUsage": {
      "reference_target_policy": "annotation_target_then_type_then_reference"
    },
    "SatisfyUsage": {
      "reference_target_policy": "type_then_reference"
    },
    "VerifyUsage": {
      "reference_target_policy": "type_then_reference"
    }
  },
  "usage_traversal_policies": {
    "StateUsage": {
      "records_previous_state": true
    }
  },
  "usage_subset_defaults": {
    "ItemUsage": {
      "owner_subsetted_feature_refs": {
        "ItemDefinition": [
          "Items::Item::subitems"
        ],
        "PartUsage": [
          "Items::Item::subitems"
        ]
      }
    },
    "AttributeUsage": {
      "specialized_feature_subset": {
        "require_feature_ref": true,
        "include_specialized_features": true
      }
    },
    "PartUsage": {
      "specialized_feature_subset": {
        "require_feature_ref": true,
        "include_specialized_features": true,
        "require_no_explicit_type_for_append_refs": true,
        "append_refs": [
          "Items::Item::subparts"
        ],
        "owner_append_refs": {
          "Package": [
            "Parts::parts"
          ]
        }
      },
      "owner_subsetted_feature_refs": {
        "Package": [
          "Parts::parts"
        ]
      }
    },
    "PerformActionUsage": {
      "specialized_feature_subset": {
        "require_multiplicity": true,
        "include_specialized_features": true
      }
    },
    "PortUsage": {
      "owner_subsetted_feature_refs": {
        "PortDefinition": [
          "Ports::Port::subports"
        ],
        "PortUsage": [
          "Ports::Port::subports"
        ]
      },
      "modifier_owner_subsetted_feature_refs": {
        "ref": {
          "PortDefinition": [
            "Ports::ports"
          ],
          "PortUsage": [
            "Ports::ports"
          ]
        }
      }
    }
  },
  "usage_family_defaults": {
    "AcceptActionUsage": {
      "type_ref": "Actions::AcceptAction",
      "subsetted_feature_refs": [
        "Actions::acceptSubactions"
      ],
      "is_variable": false
    },
    "ActionUsage": {
      "type_ref": "Actions::Action",
      "subsetted_feature_refs": [
        "Parts::Part::ownedActions"
      ],
      "owner_subsetted_feature_refs": {
        "ActionDefinition": [
          "Actions::Action::subactions"
        ],
        "ActionUsage": [
          "Actions::Action::subactions"
        ],
        "Package": [
          "Actions::actions"
        ],
        "PerformActionUsage": [
          "Actions::Action::subactions"
        ]
      },
      "is_variable": false
    },
    "ExhibitStateUsage": {
      "type_ref": "States::StateAction",
      "subsetted_feature_refs": [
        "States::exhibitedStates"
      ],
      "is_variable": true
    },
    "FlowUsage": {
      "type_ref": "Flows::Flow",
      "subsetted_feature_refs": [
        "Actions::Action::subactions",
        "Flows::flows"
      ],
      "is_variable": false
    },
    "PerformActionUsage": {
      "type_ref": "Actions::Action",
      "subsetted_feature_refs": [
        "Actions::performedActions"
      ],
      "is_variable": true
    },
    "StateUsage": {
      "type_ref": "States::StateAction",
      "subsetted_feature_refs": [
        "States::ownedStates"
      ],
      "is_variable": false
    },
    "SuccessionUsage": {
      "type_ref": "Flows::SuccessionFlow",
      "subsetted_feature_refs": [
        "Actions::ownedActions",
        "Flows::successionFlows"
      ],
      "is_variable": false
    }
  }
}
